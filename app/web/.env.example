# @revelio/web environment. Copy to .env.local (gitignored) and adjust.
# Next.js auto-loads .env.local for `next build`, `next start` and `next dev`.
# Defaults below target the dev docker-compose stack published on localhost.

# --- RUNTIME (server, read per request) ---
# Meilisearch — powers /search and the per-set card grid.
# In production use a SEARCH-ONLY key here, NOT the master key.
MEILI_HOST=http://localhost:7700
MEILI_SEARCH_KEY=masterKey

# Postgres — powers the card detail (/card/[id]) and set pages (/sets).
DATABASE_URL=postgres://revelio:revelio@localhost:5432/revelio

# --- BUILD-TIME (NEXT_PUBLIC_*, inlined at `next build` — must be set when you BUILD, not only at start) ---
# Public base URL of card images (MinIO/CDN). Empty -> tiles show names, no thumbnails.
NEXT_PUBLIC_IMAGE_BASE_URL=http://localhost:9000/card-images

# Site origin for canonical/hreflang metadata (default https://revelio.cards).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
