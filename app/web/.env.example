# @revelio/web environment. Copy to .env.local (gitignored) and adjust.
# Next.js auto-loads .env.local for `next build`, `next start` and `next dev`.
# Defaults below target the dev docker-compose stack published on localhost.

# --- RUNTIME (server, read per request) ---
# Meilisearch — powers /search and the per-set card grid.
# In production use a SEARCH-ONLY key here, NOT the master key.
MEILI_HOST=http://localhost:7700
MEILI_SEARCH_KEY=masterKey

# Scoped Meilisearch write key for editor saves (server-only; NOT the master key).
# Create it once from the master key, limited to documents.add/documents.update on the cards_* indexes:
#   curl -sX POST "$MEILI_HOST/keys" -H "Authorization: Bearer $MEILI_MASTER_KEY" -H 'Content-Type: application/json' \
#     -d '{"description":"web write","actions":["documents.add","documents.update"],"indexes":["cards-*"],"expiresAt":null}'
MEILI_WRITE_KEY=change-me-scoped-write-key

# Postgres — powers the card detail (/card/[id]) and set pages (/sets).
DATABASE_URL=postgres://revelio:revelio@localhost:5432/revelio

# --- BUILD-TIME (NEXT_PUBLIC_*, inlined at `next build` — must be set when you BUILD, not only at start) ---
# Public base URL of card images (MinIO/CDN). Empty -> tiles show names, no thumbnails.
NEXT_PUBLIC_IMAGE_BASE_URL=http://localhost:9000/images

# Site origin for canonical/hreflang metadata (default https://revelio.cards).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-in-prod
BETTER_AUTH_URL=http://localhost:3000
ADMIN_EMAILS=you@example.com

# S3/MinIO write access for image upload (server-only)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=images
S3_REGION=eu-central-1
S3_FORCE_PATH_STYLE=true
