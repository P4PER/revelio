{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://revelio.cards/schemas/sets.schema.json",
  "title": "revelio.cards Set",
  "description": "Set metadata for revelio.cards, keyed by setCode. Referenced by cards via 'setCode'.",
  "type": "object",
  "propertyNames": { "pattern": "^[A-Z0-9]+$" },
  "additionalProperties": {
    "type": "object",
    "additionalProperties": false,
    "required": ["code", "name", "isOfficial"],
    "properties": {
      "code": { "type": "string", "description": "Short code, e.g. 'BS'." },
      "name": { "type": "string", "description": "Full set name, e.g. 'Base'." },
      "releaseDate": { "type": ["string", "null"], "description": "MM-YYYY." },
      "isOfficial": { "type": "boolean", "description": "true = original WotC set (2001–2003)." },
      "cardCount": { "type": "integer", "description": "Number of cards in the dataset for this set." },
      "symbol": { "type": ["string", "null"], "description": "Set symbol image URL." }
    }
  }
}
