# =========================================================================
# revelio.cards environment variables
# Copy to .env and adjust. Defaults below match the dev docker-compose stack
# (hostnames postgres/meilisearch/minio are the compose service names; use
# localhost + published ports when running a service directly on the host).
# =========================================================================

# ---- Shared -------------------------------------------------------------
# Postgres (ingest, migrations, and the web card-detail pages from 4a-3 on)
DATABASE_URL=postgres://revelio:revelio@postgres:5432/revelio
# Meilisearch host (used by the ingest indexer AND the web search page)
MEILI_HOST=http://meilisearch:7700

# ---- Ingest job (migrate + seed Postgres + index Meili + upload images) --
# Directories the ingest reads: built dataset / i18n labels / image assets
DATA_DIR=/data
I18N_DIR=/i18n
ASSETS_DIR=/assets
# Ingest uses the MASTER key to create indexes and write documents
MEILI_MASTER_KEY=masterKey
# S3 / MinIO image hosting (uploads card images + thumbnails + set symbols)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=eu-central-1
S3_FORCE_PATH_STYLE=true

# ---- Web app (@revelio/web, Next.js) ------------------------------------
# RUNTIME (server, read per request by the /search page):
#   In production use a SEARCH-ONLY Meili key here, not the master key.
MEILI_SEARCH_KEY=masterKey
# Scoped Meilisearch write key for editor saves (server-only; NOT the master key).
# Create it once from the master key, limited to documents.add/documents.update on the cards_* indexes:
#   curl -sX POST "$MEILI_HOST/keys" -H "Authorization: Bearer $MEILI_MASTER_KEY" -H 'Content-Type: application/json' \
#     -d '{"description":"web write","actions":["documents.add","documents.update"],"indexes":["cards-*"],"expiresAt":null}'
MEILI_WRITE_KEY=change-me-scoped-write-key
# BUILD-TIME (NEXT_PUBLIC_*, inlined at `next build` — must be set when you
# build, not just when you start):
#   Public base URL of card images (MinIO/CDN). Empty -> no thumbnails.
NEXT_PUBLIC_IMAGE_BASE_URL=http://localhost:9000/images
#   Site origin for canonical/hreflang metadata (default https://revelio.cards).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Auth (Better Auth) — 4b-1
BETTER_AUTH_SECRET=change-me-in-prod
BETTER_AUTH_URL=http://localhost:3000
ADMIN_EMAILS=you@example.com
